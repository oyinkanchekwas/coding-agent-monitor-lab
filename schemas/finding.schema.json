{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/agent-monitor-lab/finding.schema.json",
  "title": "MonitorFinding",
  "type": "object",
  "required": [
    "finding_id",
    "monitor",
    "failure_mode",
    "severity",
    "confidence",
    "message",
    "evidence",
    "remediation"
  ],
  "properties": {
    "finding_id": { "type": "string" },
    "monitor": { "type": "string" },
    "failure_mode": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "message": { "type": "string" },
    "evidence": {
      "type": "object",
      "required": ["event_id", "source", "line_number", "excerpt"],
      "properties": {
        "event_id": { "type": "string" },
        "source": { "type": "string" },
        "line_number": { "type": "integer", "minimum": 1 },
        "excerpt": { "type": "string" },
        "start": { "type": ["integer", "null"] },
        "end": { "type": ["integer", "null"] }
      }
    },
    "remediation": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": { "type": "object" }
  }
}

